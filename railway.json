{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "bun run build:remote-mcp",
    "watchPatterns": ["/apps/remote-mcp/**", "/packages/core/**", "/package.json", "/bun.lock"]
  },
  "deploy": {
    "startCommand": "bun run start:remote-mcp",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
